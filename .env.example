# === Windows local (no Docker) — copy to .env then edit ===
#   copy .env.example .env
#   .\run.ps1
#
# Prerequisites on this machine:
#   - Go 1.23+          winget install GoLang.Go
#   - PostgreSQL        winget install PostgreSQL.PostgreSQL
#   - Redis             see README (Memurai / WSL / redis-server)

PORT=8080
ENV=development
LOG_LEVEL=info
# Set true to also log CORS OPTIONS preflight noise
LOG_OPTIONS=false

# Match your local Postgres user/password (Windows installer often uses "postgres")
DATABASE_URL=host=localhost user=postgres password=postgres dbname=SACAS port=5432 sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Development only — production requires a long random secret
JWT_SECRET=dev-only-insecure-jwt-secret-change-me

SENDGRID_API_KEY=
FROM_EMAIL=noreply@example.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
FROM_PHONE=

# SPA / local testing: keep CSRF off
CSRF_ENABLED=false

# Frontend origins (Vite default 5173, CRA-style 3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limit needs Redis; leave true if Redis is running
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Leave SOLVER_URL empty for easiest local testing (built-in greedy engine, no Python).
# To use OR-Tools solver: start solver-service then set:
# SOLVER_URL=http://localhost:8090
SOLVER_URL=
SOLVER_TIMEOUT_SECONDS=35
SOLVER_FALLBACK=false
