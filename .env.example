PORT=8080
ENV=development
LOG_LEVEL=info
DATABASE_URL=host=localhost user=postgres password=YOUR_PASSWORD dbname=SACAS port=5432 sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
# Development only — production requires >=32 char non-default secret
JWT_SECRET=dev-only-insecure-jwt-secret-change-me
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@example.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
FROM_PHONE=your_twilio_phone_number

# SPA dev: leave CSRF off until the frontend sends X-CSRF-Token
CSRF_ENABLED=false

# Comma-separated browser origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Phase 9 solver microservice (empty = greedy only)
SOLVER_URL=http://localhost:8090
SOLVER_TIMEOUT_SECONDS=35
# When SOLVER_URL is set, default fallback is false (do not mask infeasibility)
SOLVER_FALLBACK=false
